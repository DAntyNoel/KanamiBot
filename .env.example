DRIVER=~fastapi+~httpx
HOST=127.0.0.1
PORT=12706

NAPCAT_WORKDIR=files/napcat_runtime
NAPCAT_WEBUI_HOST=127.0.0.1
NAPCAT_WEBUI_PORT=12705
NAPCAT_WEBUI_TOKEN=change-me

# Allow both "/ping" and "ping" style commands.
COMMAND_START=["/", ""]

LOG_LEVEL=INFO

# Keep this value identical to NapCat's websocket client token.
ONEBOT_ACCESS_TOKEN=change-me

# Fill with your own QQ number(s) as strings when privileged commands are added.
SUPERUSERS=["123456789"]

# Codex GPT plugin. Leave API key blank until you enable the plugin.
CODEX_GPT_API_KEY=
CODEX_GPT_BASE_URL=https://cliproxyapi-dantynoel.onrender.com/v1
CODEX_GPT_MODEL=gpt-5.5
CODEX_GPT_IMAGE_MODEL=gpt-image-2
CODEX_GPT_ACTIVE_REPLY=false

# MemeCrafters/meme-generator API server. Run `meme download`, then `meme run`.
MEME_GENERATOR_BASE_URL=http://127.0.0.1:2233

# GPT-SoVITS TTS plugin is migrated but disabled by default.
KANAMIBOT_TTS_ENABLED=false
GPT_SOVITS_URL=http://127.0.0.1
GPT_SOVITS_PORT=9550
GPT_SOVITS_PROJECT_ROOT=
GPT_SOVITS_PYTHON_EXEC=
GPT_SOVITS_GPT_MODEL_PATH=
GPT_SOVITS_SOVITS_MODEL_PATH=
